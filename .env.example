# API origin for browser (empty = same host — use with Vite proxy or Caddy /rest + /auth)
VITE_PUBLIC_API_ORIGIN=

# Postgres (docker-compose)
POSTGRES_PASSWORD=postgres
JWT_SECRET=dev-change-this-secret-min-32-chars!!

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
VITE_TELEGRAM_BOT_USERNAME="your-bot-username"
# Public https URL (no trailing slash) — same host as Caddyfile site name
MINI_APP_URL="https://your-domain.example"
BASE_URL="https://your-domain.example"

# CORS for auth service (comma-separated or JSON array); must include production origin
ALLOWED_ORIGINS='["http://localhost:5173","http://localhost:8080","http://localhost:3000","https://your-domain.example"]'

# Application Modes
# Maintenance mode (true = enabled, false = disabled)
VITE_MAINTENANCE_MODE="false"

# Test mode (true = uses lessons_test, false = uses lessons)
VITE_TEST_MODE="false"
