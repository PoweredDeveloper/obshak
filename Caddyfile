{
	# Avoid ERR_QUIC_PROTOCOL_ERROR when UDP/443 is filtered or QUIC is flaky (browser uses HTTP/2).
	servers {
		protocols h1 h2
	}
}

# Site label = public hostname (must match DNS + TLS). Change to your domain.
obshak.space {
	@telegram path /telegram-webhook*
	handle @telegram {
		reverse_proxy telegram-bot:8080
	}
	handle /rest/* {
		reverse_proxy postgrest:3000
	}
	handle /auth/* {
		reverse_proxy auth:3001
	}
	reverse_proxy app:80
}
